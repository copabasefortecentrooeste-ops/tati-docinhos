# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# ── Admin ─────────────────────────────────────────────────────
VITE_ADMIN_PASSWORD=sua-senha-admin-aqui

# ── WhatsApp (opcional — fallback link funciona sem isso) ─────
# URL do proxy server-side para Meta Cloud API
# Necessário apenas para envio via API oficial (produção)
VITE_WA_API_URL=https://sua-api.com

# Estas variáveis ficam no SERVIDOR, nunca no frontend:
# WHATSAPP_ACCESS_TOKEN=seu_token_meta
# WHATSAPP_WEBHOOK_SECRET=seu_secret
# WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
